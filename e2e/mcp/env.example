#  OpenShift / Kubernetes (REQUIRED for cluster-connected tests)
#  Leave empty to test with local Prometheus URL only.

# KUBE_API_URL=https://api.cluster.example.com:6443
# KUBE_TOKEN=sha256~xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

#  Optional overrides (have sensible defaults)

# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=19091
# MCP_HTTP_URL=http://remote-host:19091/mcp

#  Server Management (used by make server-start*)

# METRICS_BINARY=../../kubectl-metrics
# MCP_IMAGE=quay.io/yaacov/kubectl-metrics-mcp-server:latest
# CONTAINER_ENGINE=podman

#  MCP tool verbosity (0=silent, 1=info, 2=debug)

# MCP_VERBOSE=1
